# AlphaDesk environment — copy to backend/.env and fill in.
#   cp backend/.env.example backend/.env   (PowerShell: Copy-Item)
# backend/.env is gitignored; never commit real keys.

# --- Groq LLM (required) -------------------------------------------------
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=

# --- LangSmith tracing (recommended; CLAUDE.md says keep tracing on) -----
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=alphaDesk

# --- IND Money MCP server (required for live market data) ----------------
# Streamable-HTTP URL of the IND Money MCP server.
IND_MONEY_MCP_URL=

# --- Broker (optional) ---------------------------------------------------
# Leave blank for paper-trading only. No real orders are placed unless a
# BrokerAdapter is configured (see backend/broker/README.md).
BROKER=
