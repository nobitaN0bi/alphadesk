# AlphaDesk → AgentQuant Apex environment — copy to backend/.env and fill in.
#   cp backend/.env.example backend/.env   (PowerShell: Copy-Item)
# backend/.env is gitignored; never commit real keys.
#
# === Required ===

# --- Groq LLM ---
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=

# --- LangSmith tracing (recommended; keep tracing on per CLAUDE.md) ---
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=alphaDesk

# --- IND Money MCP server (required for live market data) ---
# Streamable-HTTP URL of the IND Money MCP server.
IND_MONEY_MCP_URL=

# === Broker (optional — leave blank for paper trading) ===
# When set, the Execution node routes sized orders to the configured
# broker. Set to "dhan" to enable live trading (Phase 2.1+).
BROKER=

# --- Dhan HQ (required when BROKER=dhan) ---
# Get a key at https://dhan.co after completing onboarding.
DHAN_CLIENT_ID=
DHAN_ACCESS_TOKEN=
# Optional — override the API base URL (defaults to https://api.dhan.co).
DHAN_BASE_URL=
# Optional — rate limiter capacity (default 10 orders/sec).
DHAN_RATE_LIMIT_ORDERS_PER_SEC=10
# Optional — circuit-breaker tuning.
DHAN_CIRCUIT_BREAKER_THRESHOLD=3
DHAN_CIRCUIT_BREAKER_COOLDOWN=60
# Optional — local path to the securityId cache (default backend/data/dhan_instruments.json).
DHAN_INSTRUMENTS_PATH=

# === AgentQuant Apex (Phase 1/2/3) ===

# Live-trading master switch. Must be exactly "1", "true", or "yes" to enable
# live orders. Paper mode is the default — even with BROKER=dhan configured,
# real orders will NOT fire unless this is set AND human_approved=True in
# the running state.
AGENTQUANT_LIVE_ENABLED=

# Quantitative sizing policy (Phase 2.3).
AGENTQUANT_RISK_PER_TRADE_PCT=0.01
AGENTQUANT_MAX_POSITION_PCT=0.20
AGENTQUANT_MAX_EXPOSURE_PCT=0.80
AGENTQUANT_LIMIT_PREMIUM_PCT=0.01

# Graph persistence (Phase 1.2). "sqlite" enables SqliteSaver so graph
# resumes survive process restarts (required for Phase 2 idempotency).
# "memory" uses the in-memory saver (legacy default, dev/test only).
AGENTQUANT_CHECKPOINTER=sqlite
AGENTQUANT_CHECKPOINT_DB=quantdesk.db

# Force offline mode (skip any network refresh of the securityId cache).
# Useful in air-gapped test environments.
AGENTQUANT_OFFLINE=
